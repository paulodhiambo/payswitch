                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql(\"RECEIVED\");",
                  "    pm.expect(json.iso_status).to.eql(\"RCVD\");",
                  "    pm.expect(json.id).to.match(/^[0-9a-f-]+$/);",
