              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Document xmlns=\"urn:iso:std:iso:20022:tech:xsd:pacs.008.001.08\">\n  <FIToFICstmrCdtTrf>\n    <GrpHdr>\n      <MsgId>PAYMENT-{{$timestamp}}</MsgId>\n      <CreDtTm>{{$isoTimestamp}}</CreDtTm>\n      <NbOfTxs>1</NbOfTxs>\n      <TtlIntrBkSttlmAmt Ccy=\"USD\">500.00</TtlIntrBkSttlmAmt>\n      <IntrBkSttlmDt>{{$isoTimestamp}}</IntrBkSttlmDt>\n      <SttlmInf>\n        <SttlmMtd>CLRG</SttlmMtd>\n      </SttlmInf>\n    </GrpHdr>\n    <CdtTrfTxInf>\n      <PmtId>\n        <InstrId>INSTR-XML-{{$timestamp}}</InstrId>\n        <EndToEndId>E2E-XML-{{$timestamp}}</EndToEndId>\n        <TxId>TX-XML-{{$timestamp}}</TxId>\n        <UETR>5c4f5e3a-9b8a-4f2e-8d7c-1a2b3c4d5e6f</UETR>\n      </PmtId>\n      <IntrBkSttlmAmt Ccy=\"USD\">500.00</IntrBkSttlmAmt>\n      <ChrgBr>CRED</ChrgBr>\n      <Dbtr>\n        <Nm>ACME Corp</Nm>\n      </Dbtr>\n      <DbtrAcct>\n        <Id>\n          <Othr>\n            <Id>US123456789</Id>\n          </Othr>\n        </Id>\n      </DbtrAcct>\n      <DbtrAgt>\n        <FinInstnId>\n          <Othr>\n            <Id>BANKUS33</Id>\n          </Othr>\n        </FinInstnId>\n      </DbtrAgt>\n      <CdtrAgt>\n        <FinInstnId>\n          <Othr>\n            <Id>BANKDEFF</Id>\n          </Othr>\n        </FinInstnId>\n      </CdtrAgt>\n      <Cdtr>\n        <Nm>Euro Import GmbH</Nm>\n      </Cdtr>\n      <CdtrAcct>\n        <Id>\n          <Othr>\n            <Id>DE89370400440532013000</Id>\n          </Othr>\n        </Id>\n      </CdtrAcct>\n      <Purp>\n        <Cd>SUPP</Cd>\n      </Purp>\n      <RmtInf>\n        <Ustrd>Invoice INV-2026-001</Ustrd>\n      </RmtInf>\n    </CdtTrfTxInf>\n  </FIToFICstmrCdtTrf>\n</Document>"
            },
