            }
          ]
        },
        {
          "name": "POST /payments/lookup — camt.003 XML",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"status is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"xml\");",
                  "    const body = pm.response.text();",
                  "    pm.expect(body).to.include(\"AcctRpt\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/xml"
              },
              {
                "key": "Accept",
                "value": "application/xml"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Document xmlns=\"urn:iso:std:iso:20022:tech:xsd:camt.003.001.07\">\n  <GetAcct>\n    <MsgHdr>\n      <MsgId>COPEDUA{{$timestamp}}</MsgId>\n      <CreDtTm>{{$isoTimestamp}}</CreDtTm>\n    </MsgHdr>\n    <AcctQryDef>\n      <AcctCrit>\n        <NewCrit>\n          <SchCrit>\n            <AcctId>\n              <Id>\n                <Othr>\n                  <Id>ACC-B</Id>\n                </Othr>\n              </Id>\n            </AcctId>\n          </SchCrit>\n        </NewCrit>\n      </AcctCrit>\n    </AcctQryDef>\n  </GetAcct>\n</Document>"
            },
            "url": {
              "raw": "{{base_url}}/payments/lookup",
              "host": ["{{base_url}}"],
              "path": ["payments", "lookup"]
            }
          },
          "response": [
            {
              "name": "200 OK — camt.004 XML response",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/xml" }
              ],
              "body": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Document xmlns=\"urn:iso:std:iso:20022:tech:xsd:camt.003.001.07\">\n  <AcctRpt>\n    <MsgHdr>\n      <MsgId>ACCT-ACC-B</MsgId>\n      <CreDtTm>2026-06-21T05:00:00Z</CreDtTm>\n    </MsgHdr>\n    <RptOrErr>\n      <AcctRpt>\n        <AcctId>\n          <Id>\n            <Othr>\n              <Id>ACC-B</Id>\n            </Othr>\n          </Id>\n        </AcctId>\n        <Nm>Deutsche Exchange Bank</Nm>\n        <Ccy>USD</Ccy>\n        <LglNm>BANKDEFF</LglNm>\n      </AcctRpt>\n    </RptOrErr>\n  </AcctRpt>\n</Document>"
            }
          ]
        },
        {
