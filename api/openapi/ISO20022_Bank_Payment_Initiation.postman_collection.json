                "exec": [
                  "pm.test(\"status is ok\", () => {",
                  "    pm.response.to.have.status(200);",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql(\"ok\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/healthz",
              "host": ["{{base_url}}"],
              "path": ["healthz"]
            }
          },
          "response": [
            {
              "name": "Healthy",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\"status\":\"ok\"}"
            }
          ]
        }
      ]
    },
    {
      "name": "Account Lookup — camt.003",
      "item": [
        {
          "name": "POST /payments/lookup — JSON",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"status is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"account_number\");",
                  "    pm.expect(json).to.have.property(\"bank_name\");",
                  "    pm.expect(json).to.have.property(\"bic\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"account_number\": \"ACC-B\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/lookup",
              "host": ["{{base_url}}"],
              "path": ["payments", "lookup"]
            }
          },
          "response": [
            {
              "name": "200 OK — account found",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
