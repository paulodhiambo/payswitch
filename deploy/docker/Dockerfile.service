# Dockerfile.service — used for all services EXCEPT portal-api.
# Skips the frontend (npm) build stage entirely.

FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG SERVICE=gateway
RUN CGO_ENABLED=0 go build -o /out/service ./cmd/${SERVICE}

FROM alpine:3.19
# ca-certificates needed for outbound TLS (OTLP, external APIs, etc.)
RUN apk --no-cache add ca-certificates
COPY --from=build /out/service /service
ENTRYPOINT ["/service"]
