# =============================================================================
# /opt/payswitch/.env  — VPS environment file
#
# Copy this file to /opt/payswitch/.env and fill in your values.
# This file is loaded by pre-deploy.sh before `docker stack deploy`.
# It is NOT committed to git (excluded via .gitignore).
# =============================================================================

# ── GHCR image registry ───────────────────────────────────────────────────────
# Your GitHub Container Registry path (no trailing slash).
# Format: ghcr.io/<github-owner>/<repo-name>
GHCR_REPO=ghcr.io/your-org/payswitch

# Set automatically by CI (do not set manually when deploying via CI).
# For manual deploys: git rev-parse HEAD
IMAGE_TAG=latest

# ── GHCR authentication (on the VPS) ─────────────────────────────────────────
# A GitHub Personal Access Token with `read:packages` scope.
# Create at: https://github.com/settings/tokens
VPS_GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Your GitHub username
GITHUB_ACTOR=your-github-username

# ── Application secrets ───────────────────────────────────────────────────────
# CSRF protection secret for the portal API.
# Generate with: openssl rand -hex 32
CSRF_SECRET=change_me_to_64_hex_chars

# ── Traefik dashboard credentials ────────────────────────────────────────────
# The dashboard is exposed on port 8080, secured by HTTP basic auth.
# The password is hashed by pre-deploy.sh using openssl passwd -apr1.
# Access: http://<VPS_IP>:8080/dashboard/
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=change_me_to_a_strong_password
